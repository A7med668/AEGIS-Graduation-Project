AEGIS_BACKEND_DATABASE_URL=sqlite:///../backend-data/aegis.db
AEGIS_RAW_PAYLOAD_DIR=../backend-data/raw-payloads
# Local development only. Replace in any shared or deployed environment.
AEGIS_ACCEPTED_ENROLLMENT_TOKENS=sample-token
AEGIS_ANALYST_TOKENS=sample-token
# Comma-separated allowed CORS origins. Default: localhost:5173 only.
AEGIS_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AEGIS_PROCESS_INLINE=true
AEGIS_WORKER_POLL_INTERVAL_SECONDS=5
AEGIS_TELEMETRY_RATE_LIMIT_MAX_REQUESTS=120
AEGIS_TELEMETRY_RATE_LIMIT_WINDOW_SECONDS=60

# ── Kafka / async pipeline ────────────────────────────────────────────────────
# Set AEGIS_EVENT_PUBLISHER=kafka and AEGIS_PROCESS_INLINE=false to use the
# async Kafka pipeline.  Requires docker-compose up (zookeeper + kafka services).
AEGIS_EVENT_PUBLISHER=none
AEGIS_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
AEGIS_KAFKA_TELEMETRY_TOPIC=telemetry_events

# ── AI provider ───────────────────────────────────────────────────────────────
# Options: stub | ollama | openrouter
#
#  stub      — deterministic rule-based scoring only (no LLM calls, default)
#
#  ollama    — local Ollama instance (http://127.0.0.1:11434).
#              Requires: `ollama pull llama3` (or mistral / any model you set below).
#              Set AEGIS_LOCAL_LLM_PROVIDER=ollama to enable.
#
#  openrouter — cloud LLM via OpenRouter (https://openrouter.ai).
#              Requires: OPENROUTER_API_KEY set to your key.
#              Set AEGIS_LOCAL_LLM_PROVIDER=openrouter to enable.
AEGIS_LOCAL_LLM_PROVIDER=stub
AEGIS_LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
AEGIS_LOCAL_LLM_TIMEOUT_SECONDS=90

# Model names used when AEGIS_LOCAL_LLM_PROVIDER=ollama.
# Run `ollama list` to see what is available; `ollama pull llama3` to download.
AEGIS_LOGS_MODEL=llama3:latest
AEGIS_TELEMETRY_MODEL=llama3:latest
AEGIS_RISK_MODEL=llama3:latest

# OpenRouter settings (used when AEGIS_LOCAL_LLM_PROVIDER=openrouter OR for Shieldy chat).
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model used for AI analysis pipeline roles (all specialist + fusion roles):
OPENROUTER_MODEL=openai/gpt-4o-mini
# Model used by the Shieldy analyst chat agent:
ORCHESTRATOR_MODEL=deepseek/deepseek-v4-flash:free
CRITIC_MODEL=deepseek/deepseek-v4-flash:free
GENERAL_MODEL=deepseek/deepseek-v4-flash:free
REPORT_MODEL=deepseek/deepseek-v4-flash:free
COMMAND_MODEL=deepseek/deepseek-v4-flash:free
FAST_MODEL=deepseek/deepseek-v4-flash:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=30

# ── Google Play Integrity backend verification ────────────────────────────────
# When set, the backend calls Google's decodeIntegrityToken API to verify the
# Play Integrity token received from Android devices.  If unset (default), the
# client-reported verdict is used without server-side verification.
#
# To enable:
#   1. Enable Play Integrity API in your Google Cloud project.
#   2. Create an API key restricted to the Play Integrity API.
#   3. Set the Android app package name below.
AEGIS_GOOGLE_PLAY_INTEGRITY_API_KEY=
AEGIS_GOOGLE_PLAY_INTEGRITY_PACKAGE_NAME=

# ── Redis distributed rate limiting ──────────────────────────────────────────
# When set, both the telemetry and auth rate limiters use a shared Redis
# sliding-window counter instead of the per-process in-memory deque.
# Required for deployments with multiple API replicas.
# Leave blank to use the in-memory fallback (local dev default).
AEGIS_REDIS_URL=redis://localhost:6379/0
