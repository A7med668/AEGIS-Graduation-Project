# ─────────────────────────────────────────────────────────────────────────────
# AEGIS Backend — production environment variables
#
# Copy this file to .env (never commit .env — it is in .gitignore).
# All secrets must be supplied at runtime via the environment; none are baked
# into Docker images or committed to the repository.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Replace "aegis:aegis" with strong credentials in production.
POSTGRES_DB=aegis
POSTGRES_USER=aegis
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

AEGIS_BACKEND_DATABASE_URL=postgresql+psycopg://aegis:CHANGE_ME_STRONG_PASSWORD@postgres:5432/aegis

# ── Auth tokens ──────────────────────────────────────────────────────────────
# Comma-separated list of opaque bearer tokens.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AEGIS_ACCEPTED_ENROLLMENT_TOKENS=CHANGE_ME_TOKEN_1,CHANGE_ME_TOKEN_2
AEGIS_ANALYST_TOKENS=CHANGE_ME_ANALYST_TOKEN

# ── Kafka ─────────────────────────────────────────────────────────────────────
AEGIS_EVENT_PUBLISHER=kafka
AEGIS_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
AEGIS_KAFKA_TELEMETRY_TOPIC=telemetry_events

# ── Redis ─────────────────────────────────────────────────────────────────────
AEGIS_REDIS_URL=redis://redis:6379/0

# ── Google Play Integrity ─────────────────────────────────────────────────────
# Obtain from Google Cloud Console → Play Integrity API.
AEGIS_GOOGLE_PLAY_INTEGRITY_API_KEY=CHANGE_ME_API_KEY
AEGIS_GOOGLE_PLAY_INTEGRITY_PACKAGE_NAME=com.your.app.package

# ── AI / LLM ─────────────────────────────────────────────────────────────────
AEGIS_LOCAL_LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=CHANGE_ME_OPENROUTER_KEY
OPENROUTER_MODEL=openai/gpt-4o-mini
ORCHESTRATOR_MODEL=deepseek/deepseek-v4-flash:free
GENERAL_MODEL=deepseek/deepseek-v4-flash:free

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set to the hostname/port where the analyst dashboard is served.
AEGIS_CORS_ALLOWED_ORIGINS=https://your.domain.example

# ── Storage ───────────────────────────────────────────────────────────────────
AEGIS_RAW_PAYLOAD_DIR=/data/raw-payloads

# ── Frontend build ────────────────────────────────────────────────────────────
# URL reachable by the analyst's browser — usually the nginx HTTPS address.
VITE_AEGIS_API_URL=https://your.domain.example/api/v1
