APP_NAME=AEGIS APK Studio
APP_ENV=local
APP_VERSION=4.11.8-postgresql-operational-db
API_HOST=0.0.0.0
API_PORT=8000
STORAGE_DIR=../storage
DATABASE_PATH=../storage/aegis.db
MAX_UPLOAD_MB=250

AI_ENABLED=true
AI_REQUIRE_OLLAMA=false
AI_FAIL_OPEN=true
AI_MAX_EVIDENCE_CHARS=28000
AI_HUMAN_REVIEW_THRESHOLD=88
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_PRIMARY_MODEL=qwen3:8b
OLLAMA_REVIEWER_MODEL=mistral
OLLAMA_LOG_TRIAGE_MODEL=mistral
OLLAMA_APP_REPUTATION_MODEL=mistral

DYNAMIC_ANALYSIS_ENABLED=true
DYNAMIC_DEFAULT_DURATION_SECONDS=10
DYNAMIC_ADB_SERIAL=emulator-5554
DYNAMIC_AUTO_START_EMULATOR=true
DYNAMIC_AVD_NAME=Medium_Phone_API_36.1
DYNAMIC_EMULATOR_ARGS=-no-snapshot -no-boot-anim
DYNAMIC_EMULATOR_BOOT_TIMEOUT_SECONDS=180
DYNAMIC_MONKEY_EVENTS=5
DYNAMIC_CLEAR_LOGCAT=true
DYNAMIC_AUTO_RECOMPUTE=false
DYNAMIC_RECORD_SCREEN=true
DYNAMIC_CAPTURE_UIAUTOMATOR=true

CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

RISK_PROFILE=context-aware-permission-capped

DYNAMIC_CAPTURE_EXTENDED_ARTIFACTS=true

DYNAMIC_UNINSTALL_AFTER_ANALYSIS=true

DYNAMIC_CAPTURE_NETSTATS=true

# Dynamic analysis safety defaults
DYNAMIC_REQUIRE_EMULATOR=true
DYNAMIC_FORCE_STOP_AFTER_ANALYSIS=true


# Production hardening / local defaults
# For public/server use: set API_AUTH_ENABLED=true and use a strong secret.
API_AUTH_ENABLED=false
API_KEY=change-this-before-production
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=1000
QUEUE_ENABLED=true
QUEUE_MAX_WORKERS=2
QUEUE_MAX_PENDING=20
ALLOWED_HOSTS=127.0.0.1,localhost
SECURITY_HEADERS_ENABLED=true

# Stronger dynamic sandbox isolation
DYNAMIC_BLOCK_PHYSICAL_DEVICES=true
DYNAMIC_REJECT_EMULATOR_WITH_ACCOUNTS=false
DYNAMIC_REQUIRE_BOOT_COMPLETED=true
DYNAMIC_MAX_RUNTIME_SECONDS=180
DYNAMIC_SANDBOX_NETWORK_NOTE=Use disposable emulator networking only; do not attach personal accounts or host secrets.

# v4.9 Threat intel / sandbox
DYNAMIC_SNAPSHOT_RESET_ENABLED=false
DYNAMIC_SNAPSHOT_NAME=aegis_clean
DYNAMIC_NETWORK_ANALYSIS_ENABLED=true

# Agentic Response Engine
AGENTIC_ENABLED=true
AGENTIC_DRY_RUN=true
AGENTIC_RISK_SCORE_THRESHOLD=75
AGENTIC_QUARANTINE_ENABLED=true
AGENTIC_EMAIL_ENABLED=false
AGENTIC_EMAIL_TO=
AGENTIC_WEBHOOK_ENABLED=false
AGENTIC_WEBHOOK_URL=
AGENTIC_REQUIRE_APPROVAL_FOR_DESTRUCTIVE=true

# SMTP settings used only when AGENTIC_EMAIL_ENABLED=true and AGENTIC_DRY_RUN=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# PostgreSQL Operational DB mirror
# JSON artifacts remain available; PostgreSQL is an optional operational mirror.
OPERATIONAL_DB_ENABLED=false
DATABASE_URL=postgresql://aegis:aegis_password@127.0.0.1:5432/aegis
OPERATIONAL_DB_AUTOINIT=true
OPERATIONAL_DB_CONNECT_TIMEOUT=3
