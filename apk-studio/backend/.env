APP_NAME=AEGIS APK Studio
APP_ENV=local
APP_VERSION=4.5.0-ai-dataset-visibility
API_HOST=0.0.0.0
API_PORT=8000
STORAGE_DIR=../storage
DATABASE_PATH=../storage/aegis.db
MAX_UPLOAD_MB=250

AI_ENABLED=true
AI_REQUIRE_OLLAMA=false
AI_FAIL_OPEN=true
AI_MAX_EVIDENCE_CHARS=28000
AI_HUMAN_REVIEW_THRESHOLD=75
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_PRIMARY_MODEL=qwen3:8b
OLLAMA_REVIEWER_MODEL=mistral
OLLAMA_LOG_TRIAGE_MODEL=mistral
OLLAMA_APP_REPUTATION_MODEL=mistral

DYNAMIC_ANALYSIS_ENABLED=true
DYNAMIC_DEFAULT_DURATION_SECONDS=25
DYNAMIC_ADB_SERIAL=emulator-5554
DYNAMIC_MONKEY_EVENTS=12
DYNAMIC_CLEAR_LOGCAT=true
DYNAMIC_AUTO_RECOMPUTE=true

DYNAMIC_RECORD_SCREEN=true
DYNAMIC_CAPTURE_UIAUTOMATOR=true
DYNAMIC_FORCE_STOP_AFTER_ANALYSIS=true
DYNAMIC_CLEAR_APP_DATA_AFTER_ANALYSIS=true
DYNAMIC_UNINSTALL_AFTER_ANALYSIS=true
DYNAMIC_SANDBOX_RESET_STRATEGY=soft_cleanup

CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

AGENTIC_ENABLED=true
AGENTIC_DRY_RUN=true
AGENTIC_RISK_SCORE_THRESHOLD=75
AGENTIC_QUARANTINE_ENABLED=true

AGENTIC_EMAIL_ENABLED=false
AGENTIC_EMAIL_TO=

AGENTIC_WEBHOOK_ENABLED=false
AGENTIC_WEBHOOK_URL=