        <item name="colorOnSecondary">@color/color_primary</item>
        <item name="colorSecondary">@color/md_grey_white</item>
    </style>
    <style name="ThemeOverlay.AppCompat.DayNight" parent="@style/ThemeOverlay.AppCompat.Dark" />
