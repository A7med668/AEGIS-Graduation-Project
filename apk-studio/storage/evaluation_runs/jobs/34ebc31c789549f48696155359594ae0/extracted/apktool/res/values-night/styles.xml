<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ActionBar" parent="@style/Widget.AppCompat.Light.ActionBar.Solid.Inverse">
        <item name="background">@color/md_grey_black_dark</item>
    </style>
    <style name="AppBaseTheme" parent="@style/Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="android:colorBackground">@color/md_grey_black_dark</item>
        <item name="android:textColor">@color/md_grey_white</item>
        <item name="actionBarStyle">@style/ActionBar</item>
        <item name="actionOverflowMenuStyle">@style/PopupMenu</item>
        <item name="colorAccent">@color/color_accent</item>
        <item name="colorBackgroundFloating">@color/md_grey_black_dark</item>
        <item name="colorOnSecondary">@color/md_grey_white</item>
        <item name="colorOnSurface">@color/color_primary</item>
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorPrimaryDark">@color/color_primary_dark</item>
        <item name="colorSecondary">@color/md_grey_white</item>
        <item name="extendedFloatingActionButtonStyle">@style/Widget.App.ExtendedFloatingActionButton</item>
        <item name="floatingActionButtonStyle">@style/Widget.App.FloatingActionButton</item>
    </style>
    <style name="AppIntroDefaultHeading" parent="@style/TextAppearance.AppCompat.Display1">
        <item name="android:textSize">@dimen/appintro_headtext_size</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/default_text_color_dark</item>
        <item name="android:gravity">center|bottom</item>
        <item name="android:padding">@dimen/appintro_head_padding</item>
    </style>
    <style name="AppIntroDefaultText" parent="@style/TextAppearance.AppCompat.Body1">
        <item name="android:textSize">@dimen/appintro_desctext_size</item>
        <item name="android:textColor">@color/default_text_color_dark</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">@dimen/appintro_desc_padding</item>
    </style>
    <style name="PopupMenu" parent="@style/Widget.AppCompat.PopupMenu.Overflow">
        <item name="android:popupBackground">@color/md_grey_black</item>
    </style>
    <style name="Theme.AppCompat.DayNight" parent="@style/Theme.AppCompat" />
    <style name="Theme.AppCompat.DayNight.DarkActionBar" parent="@style/Theme.AppCompat" />
    <style name="Theme.AppCompat.DayNight.Dialog" parent="@style/Theme.AppCompat.Dialog" />
