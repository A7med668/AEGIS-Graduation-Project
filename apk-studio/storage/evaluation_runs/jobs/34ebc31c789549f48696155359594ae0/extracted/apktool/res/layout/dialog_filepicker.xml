<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout android:id="@id/filepicker_coordinator" android:layout_width="match_parent" android:layout_height="match_parent"
  xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout android:id="@id/filepicker_holder" android:layout_width="match_parent" android:layout_height="wrap_content">
        <RelativeLayout android:id="@id/filepicker_files_holder" android:layout_width="wrap_content" android:layout_height="wrap_content">
            <com.securefilemanager.app.views.Breadcrumbs android:id="@id/filepicker_breadcrumbs" android:paddingLeft="@dimen/activity_margin" android:paddingTop="@dimen/activity_margin" android:paddingRight="@dimen/activity_margin" android:paddingBottom="@dimen/medium_margin" android:layout_width="match_parent" android:layout_height="wrap_content" />
            <com.securefilemanager.app.views.MyRecyclerView android:id="@id/filepicker_list" android:scrollbars="none" android:layoutAnimation="@anim/layout_animation" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_below="@id/filepicker_breadcrumbs" app:layoutManager="com.securefilemanager.app.views.MyLinearLayoutManager" />
            <com.securefilemanager.app.views.FastScroller android:id="@id/filepicker_fastscroller" android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_alignTop="@id/filepicker_list" android:layout_alignBottom="@id/filepicker_list" android:paddingStart="@dimen/normal_margin" android:paddingEnd="0.0dp" android:layout_alignParentEnd="true">
                <include layout="@layout/fastscroller_handle_vertical" />
            </com.securefilemanager.app.views.FastScroller>
