    <string name="help_permission1_heading">Fotoaparát</string>
    <string name="help_permission_answer">Tato aplikace vyžaduje přístup k fotoaparátu, který je využit ke čtení čárových a QR kódů. Aplikace také vyžauje přístup k vašemu úložišti, aby mohla načíst kódy z vašich obrázků nebo mezi ně uložit vygenerované kódy.</string>
    <string name="help_privacy">Jak respektuje tato aplikace vaše soukromí?</string>
    <string name="help_privacy_answer">Aplikace Privacy Friendly App Example nevyžaduje žádná oprávnění. Dále neobsahuje žádné sledovací mechanismy ani reklamy.</string>
