    <string name="help_">עזרה</string>
    <string name="help_category_example">הסריקה לא עובדת, מה אני יכול לעשות?</string>
    <string name="help_data_backup">כיצד אוכל לגבות את הנתונים שלי?</string>
    <string name="help_data_backup_answer">אתה יכול להשתמש באפליקציית גיבוי ידידותית לפרטיות הנפרדת כדי לגבות ולשחזר את הנתונים של יישום זה. זה יכול לשמש גם כדי להעביר את הנתונים שלך לטלפון חדש.</string>
    <string name="help_intro">עם PRIVACY FRIENDLY QR Scanner אתה יכול לסרוק ברקודים ו-qr-codes עם תכנים שונים.</string>
    <string name="help_overview_heading">מהו סורק ברקוד ידידותי לפרטיות?</string>
    <string name="help_permission">אילו הרשאות נדרשות על ידי PRIVACY FRIENDLY QR Scanner?</string>
    <string name="help_permission1_description">האפליקציה דורשת הרשאת המצלמה, המשמשת לסריקת ברקודים וקודי qr באמצעות מצלמה.</string>
    <string name="help_permission1_heading">מצלמה</string>
    <string name="help_permission_answer">האפליקציה דורשת הרשאת המצלמה, המשמשת לסריקת ברקודים וקודי QR באמצעות מצלמה. האפליקציה גם דורשת הרשאה לגשת לאחסון שלך כדי לסרוק קודים מהתמונות שלך או לשמור קודים שנוצרו בתמונות שלך.</string>
    <string name="help_privacy">מה הופך את היישומון לידידותי לפרטיות?</string>
    <string name="help_privacy_answer">דוגמה לאפליקציה ידידותית לפרטיות אינה דורשת שום הרשאה. בנוסף, האפליקציה אינה כולל מנגנוני מעקב או פרסומת.</string>
    <string name="help_privacy_heading">אילו הרשאות נדרשות על ידי PRIVACY FRIENDLY QR Scanner?</string>
    <string name="help_usability">הסריקה לא עובדת, מה אפשר לעשות?</string>
    <string name="help_usability_answer">אם הקוד לא נסרק, נא להרחיק מעט את המצלמה מהקוד.</string>
    <string name="help_whatis">מהו סורק ברקוד ידידותי לפרטיות?</string>
    <string name="help_whatis_answer">עם סורק QR ידידותי לפרטיות אתה יכול לסרוק/ליצור ברקודים ו-qr-codes עם תכנים שונים. כמו כן, אתה יכול להעתיק/לשתף קוד QR סרוק עם יישומים אחרים, בנוסף תוכל לשמור את קוד ה-QR שנוצר בגלריה ולשתף אותו גם כן.</string>
