<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical" android:padding="16.0dp" android:layout_width="match_parent" android:layout_height="match_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:layout_width="0.0dp" android:layout_height="wrap_content" android:text="@string/playback_speed" android:layout_weight="1.0" style="@style/AntennaPod.TextView.ListItemPrimaryTitle" />
