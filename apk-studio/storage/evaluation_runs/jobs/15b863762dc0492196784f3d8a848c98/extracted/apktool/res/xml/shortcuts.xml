<?xml version="1.0" encoding="utf-8"?>
<shortcuts
  xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut android:icon="@drawable/ic_shortcut_playlist" android:enabled="true">
        <intent android:action="de.danoeh.antennapod.intents.MAIN_ACTIVITY">
            <category android:name="android.intent.category.DEFAULT" />
            <extra android:name="fragment_tag" android:value="QueueFragment" />
        </intent>
    </shortcut>
    <shortcut android:icon="@drawable/ic_shortcut_feed" android:enabled="true">
        <intent android:action="de.danoeh.antennapod.intents.MAIN_ACTIVITY">
            <category android:name="android.intent.category.DEFAULT" />
            <extra android:name="fragment_tag" android:value="EpisodesFragment" />
        </intent>
    </shortcut>
    <shortcut android:icon="@drawable/ic_shortcut_subscriptions" android:enabled="true">
        <intent android:action="de.danoeh.antennapod.intents.MAIN_ACTIVITY">
            <category android:name="android.intent.category.DEFAULT" />
            <extra android:name="fragment_tag" android:value="SubscriptionFragment" />
        </intent>
    </shortcut>
    <shortcut android:icon="@drawable/ic_shortcut_refresh" android:enabled="true">
        <intent android:action="de.danoeh.antennapod.intents.MAIN_ACTIVITY">
            <category android:name="android.intent.category.DEFAULT" />
            <extra android:name="refresh_on_start" android:value="true" />
        </intent>
    </shortcut>
</shortcuts>
