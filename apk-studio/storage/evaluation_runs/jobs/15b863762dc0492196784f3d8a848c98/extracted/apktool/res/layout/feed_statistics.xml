<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
        <include android:id="@id/playbackTime" layout="@layout/feed_statistics_card" />
        <include android:id="@id/episodesStarted" layout="@layout/feed_statistics_card" />
        <include android:id="@id/spaceDownloaded" layout="@layout/feed_statistics_card" />
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:id="@id/secondRowContainer" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content">
        <include android:id="@id/durationTotal" layout="@layout/feed_statistics_card" />
        <include android:id="@id/episodesTotal" layout="@layout/feed_statistics_card" />
        <include android:id="@id/episodesDownloaded" layout="@layout/feed_statistics_card" />
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
        <include android:id="@id/expectedNextEpisode" layout="@layout/feed_statistics_card" />
        <include android:id="@id/episodeSchedule" layout="@layout/feed_statistics_card" />
    </LinearLayout>
</LinearLayout>
