# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_DB=aegis
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis
AEGIS_BACKEND_DATABASE_URL=postgresql+psycopg://aegis:aegis@postgres:5432/aegis

# ── Auth ──────────────────────────────────────────────────────────────────
AEGIS_ACCEPTED_ENROLLMENT_TOKENS=sample-token
AEGIS_ANALYST_TOKENS=sample-token

# ── Kafka ─────────────────────────────────────────────────────────────────
AEGIS_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
AEGIS_KAFKA_TELEMETRY_TOPIC=telemetry_events

# ── Redis ─────────────────────────────────────────────────────────────────
AEGIS_REDIS_URL=redis://redis:6379/0

# ── API ───────────────────────────────────────────────────────────────────
AEGIS_API_URL=http://nginx:80/api/v1
AEGIS_RAW_PAYLOAD_DIR=/data/raw-payloads
AEGIS_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8501,http://localhost

# ── AI / LLM ──────────────────────────────────────────────────────────────
AEGIS_LOCAL_LLM_PROVIDER=ollama
AEGIS_LOCAL_LLM_BASE_URL=http://host.docker.internal:11434
AEGIS_LOCAL_LLM_TIMEOUT_SECONDS=180
AEGIS_LOGS_MODEL=llama3:latest
AEGIS_TELEMETRY_MODEL=llama3:latest
AEGIS_RISK_MODEL=llama3:latest
AEGIS_SHIELDY_EMBEDDING_MODEL=nomic-embed-text:latest
AEGIS_SHIELDY_RAG_MODEL=qwen3:8b
# AEGIS_SHIELDY_RAG_MIN_RELEVANCE=0.03
# AEGIS_SHIELDY_RAG_TOP_K=3
# AEGIS_SHIELDY_MAX_CONTEXT_CHARS=3000
AEGIS_SHIELDY_WEB_SEARCH_ENABLED=true
AEGIS_SHIELDY_WEB_SEARCH_MAX_RESULTS=3
AEGIS_SHIELDY_QUALITY_GATE_ENABLED=false
AEGIS_SHIELDY_RAG_DEBUG=false
# ── Admin ─────────────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# AEGIS_SHIELDY_VECTOR_COLLECTION=security_assistant
AEGIS_SHIELDY_VECTOR_DB_PATH=/app/app/shieldy/Data/Vector_Database_v2
AEGIS_SHIELDY_VECTOR_COLLECTION=security_assistant_v2
AEGIS_SHIELDY_RAG_TOP_K=5
AEGIS_SHIELDY_MAX_CONTEXT_CHARS=6000
AEGIS_SHIELDY_RAG_MIN_RELEVANCE=0.03